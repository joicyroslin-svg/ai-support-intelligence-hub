# AI Support Intelligence Dashboard environment variables
# Copy this file to .env and edit values.

# Free-first AI setup (recommended)
HF_TOKEN=
HF_MODEL=HuggingFaceTB/SmolLM2-1.7B-Instruct
HF_API_URL_BASE=https://router.huggingface.co/v1
DEFAULT_MODEL=huggingface/HuggingFaceTB/SmolLM2-1.7B-Instruct

# Optional multi-model support
GEMINI_API_KEY=
OPENAI_API_KEY=

# Optional comma-separated model list shown in UI
AVAILABLE_MODELS=huggingface/HuggingFaceTB/SmolLM2-1.7B-Instruct,huggingface/mistralai/Mistral-7B-Instruct-v0.3,gemini/gemini-1.5-flash,openai/gpt-4o-mini

# App settings
RAG_PERSIST=./data/chroma_db
DEBUG=false
